# ==============================
# DATABASE (MySQL via Docker)
# ==============================
# รูปแบบ: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/db"

# ==============================
# SERVER
# ==============================
PORT=4000

# ==============================
# AUTH
# ==============================
JWT_SECRET=change-this-to-a-long-random-string

# ==============================
# EMAIL (problem notifications + password reset links)
# ==============================
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-gmail-app-password

# ==============================
# FRONTEND
# ==============================
# Used to build links sent in emails (e.g. password reset). Must point to
# wherever the Next.js frontend is actually running.
FRONTEND_URL=http://localhost:3000

